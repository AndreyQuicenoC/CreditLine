# Backend Configuration
DEBUG=True
SECRET_KEY=your_secret_key_here_generate_with_secrets.token_urlsafe(50)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database (Postgres) - use a connection string appropriate for your environment
# Example: postgresql://<user>:<password>@<host>:5432/<dbname>
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.example.com:5432/postgres

# Supabase Configuration (replace with your project values)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_from_supabase_dashboard
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_from_supabase_dashboard

# Frontend Configuration
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_from_supabase_dashboard
VITE_API_TIMEOUT=10000
